<UserControl x:Class="AccuratPanelCarWashing.Controls.CalculatorOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AccuratPanelCarWashing"
             xmlns:controls="clr-namespace:AccuratPanelCarWashing.Controls"
             xmlns:models="clr-namespace:AccuratPanelCarWashing.Models"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.Resources>
        <!-- Стиль кнопок классического калькулятора -->
        <Style x:Key="CalcBttnStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#DCDDE1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="45"/>
            <!-- Чуть увеличил для удобства -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EBF5FB"/>
                                <Setter Property="BorderBrush" Value="#3498DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Анимации (теперь полностью синхронизированы с AppointmentsOverlay) -->
        <Storyboard x:Key="ShowAnimation">
            <DoubleAnimation Storyboard.TargetName="OverlayBackground" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
            <DoubleAnimation Storyboard.TargetName="PopupPanel" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="PopupPanel" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.8" To="1" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PopupPanel" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.8" To="1" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="HideAnimation">
            <DoubleAnimation Storyboard.TargetName="OverlayBackground" Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="PopupPanel" Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetName="PopupPanel" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1" To="0.9" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PopupPanel" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1" To="0.9" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <!-- ГЛАВНЫЙ КОНТЕЙНЕР -->
    <Border x:Name="OverlayBackground" 
            Background="#A6000000" 
            Visibility="Collapsed" 
            Opacity="0"
            HorizontalAlignment="Stretch" 
            VerticalAlignment="Stretch"
            MouseLeftButtonDown="Overlay_MouseLeftButtonDown">

        <Border x:Name="PopupPanel" 
                Background="#F5F6FA" 
                CornerRadius="20" 
                Width="500" Height="1030" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                Opacity="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="10" Opacity="0.4"/>
            </Border.Effect>
            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
            </Border.RenderTransform>

            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="🧮 Калькулятор" FontSize="24" FontWeight="Black" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Переключатель режимов (СТИЛЬ ИЗ MAINWINDOW) -->
                <TabControl Grid.Row="1" 
                            Background="#f0f0f2" 
                            BorderThickness="0" 
                            Margin="0,0,0,15">
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem">
                            <Setter Property="Padding" Value="10,5"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="Border" Background="Transparent" CornerRadius="6" Margin="2,2,2,0" Padding="10,5">
                                            <ContentPresenter ContentSource="Header"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#3498DB"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.ItemContainerStyle>

                    <TabControl.Items>
                        <TabItem Header="Классический" IsSelected="True">
                            <Grid Margin="0,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Дисплей -->
                                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20" 
                                        BorderBrush="#DCDDE1" BorderThickness="1" HorizontalAlignment="Right" Width="320">
                                    <TextBlock Text="{Binding ClassicResult}" FontSize="36" FontWeight="Bold" 
                                               Foreground="#2C3E50" TextAlignment="Right" TextWrapping="Wrap"/>
                                </Border>

                                <UniformGrid Grid.Row="1" Columns="4" Rows="5">
                                    <Button Content="C" Style="{StaticResource CalcBttnStyle}" Click="Calc_Clear_Click" Background="#FADBD8" Foreground="#E74C3C"/>
                                    <Button Content="±" Style="{StaticResource CalcBttnStyle}" Click="Calc_Sign_Click"/>
                                    <Button Content="%" Style="{StaticResource CalcBttnStyle}" Click="Calc_Percent_Click"/>
                                    <Button Content="÷" Style="{StaticResource CalcBttnStyle}" Click="Calc_Op_Click" Background="#EBF5FB"/>

                                    <Button Content="7" Style="{StaticResource CalcBttnStyle}" Click="Calc_Num_Click"/>
                                    <Button Content="8" Style="{StaticResource CalcBttnStyle}" Click="Calc_Num_Click"/>
                                    <Button Content="9" Style="{StaticResource CalcBttnStyle}" Click="Calc_Num_Click"/>
                                    <Button Content="×" Style="{StaticResource CalcBttnStyle}" Click="Calc_Op_Click" Background="#EBF5FB"/>

                                    <Button Content="4" Style="{StaticResource CalcBttnStyle}" Click="Calc_Num_Click"/>
                                    <Button Content="5" Style="{StaticResource CalcBttnStyle}" Click="Calc_Num_Click"/>
                                    <Button Content="6" Style="{StaticResource CalcBttnStyle}" Click="Calc_Num_Click"/>
                                    <Button Content="-" Style="{StaticResource CalcBttnStyle}" Click="Calc_Op_Click" Background="#EBF5FB"/>

                                    <Button Content="1" Style="{StaticResource CalcBttnStyle}" Click="Calc_Num_Click"/>
                                    <Button Content="2" Style="{StaticResource CalcBttnStyle}" Click="Calc_Num_Click"/>
                                    <Button Content="3" Style="{StaticResource CalcBttnStyle}" Click="Calc_Num_Click"/>
                                    <Button Content="+" Style="{StaticResource CalcBttnStyle}" Click="Calc_Op_Click" Background="#EBF5FB"/>

                                    <Button Content="" Style="{StaticResource CalcBttnStyle}" Background="#f0f0f2"/>
                                    <Button Content="0" Style="{StaticResource CalcBttnStyle}" Click="Calc_Num_Click"/>
                                    <Button Content="," Style="{StaticResource CalcBttnStyle}" Click="Calc_Comma_Click"/>
                                    <Button Content="=" Style="{StaticResource CalcBttnStyle}" Click="Calc_Equal_Click" Background="#27AE60" Foreground="White"/>
                                </UniformGrid>
                            </Grid>
                        </TabItem>

                        

                        <TabItem Header="Денежный">
                            <Grid Margin="0,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F5F6FA"> 
                                    <ItemsControl ItemsSource="{Binding Denominations}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" CornerRadius="12" Margin="0,0,0,10" BorderBrush="#DCDDE1" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" 
                                                                           FontSize="16" Foreground="Black" 
                                                                           VerticalAlignment="Center" Margin="12,0,0,0"/>

                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Button Content="-" Width="35" Height="35" Cursor="Hand" FontSize="18"
                                                                    Click="Money_Minus_Click" Tag="{Binding}" Background="#3498DB" BorderBrush="#DCDDE1"/>
                                                            <TextBox Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}" 
                                                                     Height="45" Width="60" TextAlignment="Center" Margin="10,0" 
                                                                     FontSize="15" VerticalAlignment="Center"
                                                                     BorderThickness="0.5"/>
                                                            <Button Content="+" Width="35" Height="35" Cursor="Hand" FontSize="18"
                                                                    Click="Money_Plus_Click" Tag="{Binding}" Background="#3498DB" BorderBrush="#DCDDE1"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Border Grid.Row="1" Background="#2C3E50" CornerRadius="15" Padding="25" Margin="0,20,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="ИТОГО В КАССЕ: " Foreground="#BDC3C7" FontSize="15" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding MoneyTotal, StringFormat={}{0:N0} ₽}" 
                                                   Foreground="#27AE60" FontSize="28" FontWeight="Black" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>


                    </TabControl.Items>
                </TabControl>
                
                

                <!-- Кнопка закрытия -->
                <Button Grid.Row="3" Content="✖ Закрыть" Click="CloseButton_Click" 
                        Width="160" Height="45" Background="#E74C3C" Foreground="White" 
                        FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand"
                        HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Border>
</UserControl>
