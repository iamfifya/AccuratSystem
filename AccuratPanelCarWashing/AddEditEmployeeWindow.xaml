<Window x:Class="AccuratPanelCarWashing.AddEditEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AccuratPanelCarWashing"
        xmlns:controls="clr-namespace:AccuratPanelCarWashing.Controls"
        Title="Редактирование сотрудника"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize" 
        Width="500" Height="750" 
        Background="#F5F6FA"
        BorderBrush="Black"
        BorderThickness="1"
        WindowStyle="None"
        Foreground="Black">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <!-- 1. Область со скроллом (занимает всё свободное место) -->
            <RowDefinition Height="*"/>
            <!-- 2. Область с кнопками (всегда прижата к низу) -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- С КРОЛЛВОЙЕРОМ -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <!-- Используем StackPanel вместо Grid с 20 строками. 
                 Теперь элементы просто идут друг за другом! -->
            <StackPanel Margin="0,0,10,20">

                <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" 
                           Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <Label Content="ФИО:" Margin="0,5" FontWeight="SemiBold"/>
                <TextBox Text="{Binding CurrentEmployee.FullName, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,5" Height="50" Padding="5" Foreground="Black"/>

                <Label Content="📱 Телефон:" Margin="0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="PhoneTextBox" Text="{Binding CurrentEmployee.Phone, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,5" Height="50" Padding="5" Foreground="Black"
                         PreviewTextInput="PhoneTextBox_PreviewTextInput"
                         TextChanged="PhoneTextBox_TextChanged" MaxLength="20"/>
                <TextBlock Text="   формат: 89996094363" Foreground="#95A5A6" 
                           Margin="0,0,0,10" FontSize="11" HorizontalAlignment="Left"/>

                <Label Content="Логин:" Margin="0,5" FontWeight="SemiBold"/>
                <TextBox Text="{Binding CurrentEmployee.Login, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,5" Height="50" Padding="5" Foreground="Black"/>

                <Label Content="Пароль:" Margin="0,5" FontWeight="SemiBold"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,5" Height="50" Padding="5" Foreground="Black" VerticalContentAlignment="Center"/>

                <Label Content="Должность:" Margin="0,5,0,0" FontWeight="SemiBold"/>
                <controls:CustomComboBox x:Name="RoleComboBox" 
                                         Margin="0,5" 
                                         Height="40" 
                                         Placeholder="Выберите должность"
                                         DisplayMemberPath="Value" 
                                         SelectedValuePath="Key"
                                         SelectedValue="{Binding CurrentEmployee.Role, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Ставка зарплаты (%):" Margin="0,5,0,0" FontWeight="SemiBold"/>
                <TextBox Text="{Binding CurrentEmployee.BaseWagePercentage, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,5" Height="40" Padding="5" Foreground="Black"/>

                <Label Content="💰 Фиксированный оклад за смену (выход):" FontWeight="SemiBold" Margin="0,10,0,0"/>
                <TextBox x:Name="SalaryTextBox" Height="40" Padding="5" VerticalContentAlignment="Center"
                         Text="{Binding CurrentEmployee.BaseSalaryPerShift, UpdateSourceTrigger=PropertyChanged, FallbackValue=0}"/>

                <Label Content="📂 Филиал привязки:" Margin="0,10,0,0" FontWeight="SemiBold"/>
                <controls:CustomComboBox x:Name="BranchComboBox" 
                                         Margin="0,5" 
                                         Height="40" 
                                         Placeholder="Выберите филиал"
                                         DisplayMemberPath="Name" 
                                         SelectedValuePath="Id"
                                         SelectedValue="{Binding CurrentEmployee.BranchId, UpdateSourceTrigger=PropertyChanged}"/>

                <CheckBox Content="Трудоустроен" IsChecked="{Binding CurrentEmployee.IsActive}" 
                          Margin="0,15" HorizontalAlignment="Left" Foreground="Black"/>
            </StackPanel>
        </ScrollViewer>

        <!-- КНОПКИ (вне скролла, всегда видны) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
            <Button Content="✓ Сохранить" Click="SaveButton_Click" Width="100" Height="35" 
                    Margin="5" Background="#27AE60" Foreground="White" Cursor="Hand"/>
            <Button Content="✗ Отмена" Click="CloseButton_Click" Width="100" Height="35" 
                    Margin="5" Background="#E74C3C" Foreground="White" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
