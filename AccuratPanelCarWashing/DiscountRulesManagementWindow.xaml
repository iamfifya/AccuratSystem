<Window x:Class="AccuratPanelCarWashing.DiscountRulesManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AccuratPanelCarWashing.Controls" 
        xmlns:local="clr-namespace:AccuratPanelCarWashing"
        Title="Управление правилами скидок" Height="600" Width="700"
        WindowStartupLocation="CenterScreen" Background="#F5F6FA" WindowStyle="ToolWindow">

    <Window.Resources>
        <local:BooleanToDiscountTypeConverter x:Key="BooleanToDiscountTypeConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

            <TextBlock Text="🎁 Настройка Правил Скидок" FontSize="22" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,15"/>

            <!-- Блок создания нового правила -->
            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#BDC3C7" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="➕ Создать новое правило" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Название (например: 'Дождь' или 'Пенсионер'):" Foreground="#7F8C8D" FontSize="11"/>
                            <TextBox x:Name="RuleNameTextBox" Height="40" Padding="5" VerticalContentAlignment="Center" Margin="0,0,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Значение:" Foreground="#7F8C8D" FontSize="11"/>
                            <TextBox x:Name="RuleValueTextBox" Height="40" Padding="5" Width="80" VerticalContentAlignment="Center" TextAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                            <TextBlock Text="Тип скидки:" Foreground="#7F8C8D" FontSize="11"/>
                        <controls:CustomComboBox x:Name="RuleTypeCombo" Height="40" SelectedValuePath="Tag" Placeholder="Тип...">
                            <controls:CustomComboBox.Items>
                                <ComboBoxItem Content="Процент (%)" Tag="True"/>
                                <ComboBoxItem Content="Сумма (₽)" Tag="False"/>
                            </controls:CustomComboBox.Items>
                        </controls:CustomComboBox>
                    </StackPanel>
                    </Grid>

                    <Button Content="Сохранить правило" Click="SaveRule_Click" 
                        Background="#27AE60" Foreground="White" Width="150" Height="40" 
                        FontWeight="Bold" Cursor="Hand" HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>

            <!-- Список существующих правил -->
            <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10" BorderBrush="#BDC3C7" BorderThickness="1">
                <ListBox x:Name="RulesListBox" 
                     Background="Transparent" 
                     BorderThickness="0" 
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#EBF5FB" BorderBrush="#3498DB" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="#2C3E50"/>
                                        <TextBlock Text="{Binding Value, StringFormat='Значение: {0}'}" FontSize="13" Foreground="#7F8C8D"/>
                                        <TextBlock Text="{Binding IsPercentage, Converter={StaticResource BooleanToDiscountTypeConverter}}"
                                                   FontSize="11" Foreground="#3498DB" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="🗑 Удалить" Click="DeleteRule_Click" 
                                        Background="#E74C3C" Foreground="White" Padding="10,5" 
                                        VerticalAlignment="Center" Cursor="Hand"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
    </Grid>
</Window>
