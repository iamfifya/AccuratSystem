<Window x:Class="AccuratPanelCarWashing.UpsellManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AccuratPanelCarWashing.Controls"
        Title="Настройка умного кассира" Height="650" Width="800"
        WindowStartupLocation="CenterScreen" Background="#F5F6FA" WindowStyle="ToolWindow">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🧠 Настройка Умного Кассира (Upsell)" FontSize="22" FontWeight="Bold" Foreground="#F57F17" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#BDC3C7" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="➕ Создать новое правило допродажи" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Если клиент выбрал эту услугу:" Foreground="#7F8C8D" FontSize="11"/>
                        <controls:CustomComboBox x:Name="TriggerServiceCombo" Height="40" DisplayMemberPath="Name" SelectedValuePath="Id" Placeholder="Выберите триггер..."/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="👉" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Предложить ему купить эту:" Foreground="#7F8C8D" FontSize="11"/>
                        <controls:CustomComboBox x:Name="SuggestedServiceCombo" Height="40" DisplayMemberPath="Name" SelectedValuePath="Id" Placeholder="Выберите допродажу..."/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Текст подсказки для кассира:" Foreground="#7F8C8D" FontSize="11"/>
                <TextBox x:Name="MessageTextBox" Height="40" Padding="5" VerticalContentAlignment="Center" Margin="0,0,0,10" 
                         Text="Например: Предложите антидождь, сейчас на него акция!"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Премия (бонус) кассиру за продажу: " VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="BonusTextBox" Grid.Column="1" Height="40" Padding="5" Margin="5,0" Text="50"/>
                    <Button Grid.Column="2" Content="Сохранить правило" Click="AddRuleButton_Click" Background="#27AE60" Foreground="White" Width="150" Height="40" FontWeight="Bold" Cursor="Hand"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10" BorderBrush="#BDC3C7" BorderThickness="1">
            <ListBox x:Name="RulesListBox" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FFF9C4" BorderBrush="#FBC02D" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding TriggerServiceName, StringFormat='Если: {0}'}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding SuggestedServiceName, StringFormat='Предложить: {0}'}" Foreground="#E67E22" FontWeight="Bold" FontSize="14" Margin="0,2"/>
                                    <TextBlock Text="{Binding Rule.Message, StringFormat='Подсказка: &quot;{0}&quot;'}" FontStyle="Italic" Foreground="#7F8C8D" FontSize="11"/>
                                    <TextBlock Text="{Binding Rule.BonusAmount, StringFormat='Бонус: {0:N0} ₽'}" Foreground="#27AE60" FontWeight="Bold" Margin="0,5,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="🗑 Удалить" Click="DeleteRuleButton_Click" Background="#E74C3C" Foreground="White" Padding="10,5" VerticalAlignment="Center" Cursor="Hand"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</Window>