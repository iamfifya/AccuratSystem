<Window x:Class="AccuratPanelCarWashing.AddEditServiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AccuratPanelCarWashing"
        xmlns:controls="clr-namespace:AccuratPanelCarWashing.Controls"
        mc:Ignorable="d"
        Title="Добавление/Редактирование услуги"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="550" Height="800"
        Background="#F5F6FA"
        BorderBrush="Black"
        BorderThickness="1"
        WindowStyle="None">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            
            <StackPanel Margin="0,0,10,20">
                <TextBlock Text="{Binding WindowTitle}" FontSize="20" FontWeight="Bold" 
                   Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <Label Content="Название услуги:" Grid.Row="1" Margin="0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="NameTextBox" Text="{Binding CurrentService.Name, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,5" Height="50" Padding="5"/>

                <Label Content="Цены по категориям кузова:" Margin="0,5" FontWeight="SemiBold"/>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="5">
                        <Label Content="Категория 1 (Легковая)" FontSize="10"/>
                        <TextBox x:Name="PriceCategory1TextBox" Height="50" Padding="5" Text="0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5">
                        <Label Content="Категория 2 (Универсал)" FontSize="10"/>
                        <TextBox x:Name="PriceCategory2TextBox" Height="50" Padding="5" Text="0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="5">
                        <Label Content="Категория 3 (Кроссовер)" FontSize="10"/>
                        <TextBox x:Name="PriceCategory3TextBox" Height="50" Padding="5" Text="0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="5">
                        <Label Content="Категория 4 (Внедорожник)" FontSize="10"/>
                        <TextBox x:Name="PriceCategory4TextBox" Height="50" Padding="5" Text="0"/>
                    </StackPanel>
                </Grid>

                <Label Content="Длительность (минуты):" Margin="0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="DurationTextBox" Text="{Binding CurrentService.DurationMinutes, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,5" Height="50" Padding="5"/>

                <Label Content="Описание:" Margin="0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="DescriptionTextBox" Text="{Binding CurrentService.Description, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,5" Height="80" Padding="5" TextWrapping="Wrap" AcceptsReturn="True"/>

                <Label Content="Индивидуальный % зарплаты за услугу:" Margin="0,5,0,0" FontWeight="SemiBold"/>
                <TextBox x:Name="CustomWageTextBox" 
                         Text="{Binding CurrentService.CustomWagePercentage, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,5" Height="40" Padding="5" 
                         ToolTip="Оставьте пустым, чтобы использовать базовую ставку сотрудника"/>
                <TextBlock Text="Если указать здесь процент, он перекроет базовую ставку мойщика для этой услуги." 
                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>

                <!-- Категория услуги -->
                <Label Content="📂 Категория услуги:" Margin="0,5,0,0" FontWeight="SemiBold"/>
                <controls:CustomComboBox x:Name="CategoryComboBox" 
                         Margin="0,5" 
                         Height="50"
                         Placeholder="Выберите категорию услуги"
                         SelectedValue="{Binding CurrentService.ServiceCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         SelectedValuePath="Tag">
                    <controls:CustomComboBox.Items>
                        <ComboBoxItem Content="💦 Мойка (автомойка)" Tag="0"/>
                        <ComboBoxItem Content="🔧 Сервис (ремонт/ТО)" Tag="1"/>
                    </controls:CustomComboBox.Items>
                </controls:CustomComboBox>

            </StackPanel>

        </ScrollViewer>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="1" Margin="0,15">
                <Button Content="✅ Сохранить" Click="SaveButton_Click" Width="120" Height="35" 
                    Margin="5" Background="#27AE60" Foreground="White" Cursor="Hand"/>
                <Button Content="✖ Отмена" Click="CloseButton_Click" Width="100" Height="35" 
                    Margin="5" Background="#E74C3C" Foreground="White" Cursor="Hand"/>
            </StackPanel>
    </Grid>
</Window>
