<Window x:Class="AccuratPanelCarWashing.BranchManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление филиалами" 
        Height="550" Width="850"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F6FA"
        BorderBrush="Black"
        BorderThickness="1"
        Foreground="Black"
        Focusable="True">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,15,0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Ваши филиалы" FontWeight="Bold" FontSize="18" Margin="0,0,0,15" Foreground="#2C3E50"/>

                <ListBox x:Name="BranchesListBox" Grid.Row="1" 
                         DisplayMemberPath="Name" 
                         SelectionChanged="BranchesListBox_SelectionChanged"
                         BorderThickness="1" BorderBrush="#E0E0E0" Background="#FAFAFA"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Padding="5"/>

                <Button Grid.Row="2" Content="➕ Добавить филиал" Margin="0,15,0,0" Height="35" 
                        Background="#3498DB" Foreground="White" FontWeight="Bold" Cursor="Hand"
                        Click="AddNewBranch_Click"/>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="25">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid x:Name="EditPanel" Grid.Row="0" IsEnabled="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="EditTitleTextBlock" Text="Редактирование филиала" FontWeight="Bold" FontSize="20" Foreground="#2C3E50" Margin="0,0,0,20"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <Label Content="Название филиала:" FontWeight="SemiBold"/>
                            <TextBox x:Name="NameTextBox" Height="35" Padding="5"/>

                            <Label Content="Адрес:" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <TextBox x:Name="AddressTextBox" Height="35" Padding="5" />

                            <Label Content="Телефон:" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <TextBox x:Name="PhoneTextBox" Height="35" Padding="5" />

                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <Label Content="Постов мойки (шт):" FontWeight="SemiBold"/>
                                    <TextBox x:Name="WashBaysTextBox" Height="35" Padding="5"  PreviewTextInput="NumericOnly_PreviewTextInput"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <Label Content="Подъёмников сервиса (шт):" FontWeight="SemiBold"/>
                                    <TextBox x:Name="ServiceLiftsTextBox" Height="35" Padding="5"  PreviewTextInput="NumericOnly_PreviewTextInput"/>
                                </StackPanel>
                            </Grid>

                            <CheckBox x:Name="IsActiveCheckBox" Content="Филиал активен (работает)" 
                                      FontWeight="SemiBold"  Margin="0,20,0,0" Foreground="#27AE60"/>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Content="✅ Сохранить" Height="35" Width="120" Margin="0,0,10,0"
                                Background="#27AE60" Foreground="White" FontWeight="Bold" Cursor="Hand"
                                Click="SaveBranch_Click"/>

                        <Button x:Name="DeleteButton" Content="🗑 Удалить" Height="35" Width="100"
                                Background="#E74C3C" Foreground="White" FontWeight="Bold" Cursor="Hand"
                                Click="DeleteBranch_Click"/>
                    </StackPanel>
                </Grid>
                <Button Grid.Row="1" Content="✖ Вернуться к столу управляющего" Click="CloseButton_Click" Width="250" Height="35" 
                        Background="#34495E" Foreground="White" Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>