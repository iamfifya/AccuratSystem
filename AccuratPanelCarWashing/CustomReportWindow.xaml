<Window x:Class="AccuratPanelCarWashing.CustomReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AccuratPanelCarWashing"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Интервальный отчет"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        MinWidth="1100" MinHeight="750" Width="1200" Height="850"
        Background="#F5F6FA" WindowStyle="None" WindowState="Maximized" Foreground="Black">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Шапка с вкладками -->
            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- Фильтры дат -->
            <RowDefinition Height="*"/>
            <!-- Контент -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопки управления -->
        </Grid.RowDefinitions>

        <!-- 1. Вкладки (Стилистика как в ReportsWindow) -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="📊 Аналитика за период" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center" Margin="0,0,20,0"/>

            <TabControl Grid.Column="1" 
                        ItemsSource="{Binding BranchTabs}" 
                        SelectedItem="{Binding SelectedBranchTab, Mode=TwoWay}"
                        Background="Transparent" 
                        BorderThickness="0"
                        VerticalAlignment="Center">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
                        <Setter Property="Visibility" Value="{Binding DataContext.IsDirector, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Style>
                </TabControl.ItemContainerStyle>
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding BranchName}" FontSize="12" FontWeight="Bold"/>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate/>
                </TabControl.ContentTemplate>
            </TabControl>
        </Grid>

        <!-- 2. Подзаголовок филиала -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,15">
            <TextBlock Text="{Binding SelectedBranchTab.BranchName}" FontSize="16" Foreground="#7F8C8D" HorizontalAlignment="Center" FontWeight="SemiBold"/>
        </StackPanel>

        <!-- 3. Фильтры дат -->
        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Label Content="С:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                <local:CustomDatePicker x:Name="StartDatePicker" Height="40" Width="200"/>

                <Label Content="По:" VerticalAlignment="Center" Margin="20,0,5,0" FontWeight="SemiBold"/>
                <local:CustomDatePicker x:Name="EndDatePicker" Height="40" Width="200"/>

                <Button Content="🚀 Сформировать отчет" Click="GenerateReportButton_Click" 
                        Width="180" Height="40" Margin="30,0,0,0" 
                        Background="#3498DB" Foreground="White" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <!-- 4. Основной контент -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ReportContent" Visibility="Collapsed" Margin="0,0,0,20">

                <!-- Верхние карточки (Общее) -->
                <UniformGrid Columns="4" Margin="0,0,0,20">
                    <Border Style="{StaticResource StatCard}" Margin="5">
                        <StackPanel>
                            <TextBlock Text="💰 Общая выручка" FontSize="12" Foreground="#7F8C8D"/>
                            <TextBlock x:Name="TotalRevenueText" FontSize="22" FontWeight="Bold" Foreground="#27AE60"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}" Margin="5" Background="#34495E">
                        <StackPanel>
                            <TextBlock Text="💎 Чистая прибыль" FontSize="12" Foreground="#BDC3C7"/>
                            <TextBlock x:Name="NetProfitText" FontSize="22" FontWeight="Bold" Foreground="#2ECC71"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}" Margin="5">
                        <StackPanel>
                            <TextBlock Text="🚗 Всего заказов" FontSize="12" Foreground="#7F8C8D"/>
                            <TextBlock x:Name="TotalCarsText" FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}" Margin="5">
                        <StackPanel>
                            <TextBlock Text="👥 Новых клиентов" FontSize="12" Foreground="#7F8C8D"/>
                            <TextBlock x:Name="NewClientsText" FontSize="22" FontWeight="Bold" Foreground="#3498DB"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- ГРАФИКИ -->
                <Grid Height="320" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="10" Margin="5">
                        <lvc:CartesianChart Series="{Binding RevenueSeries}" LegendLocation="None">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="Даты" Labels="{Binding Labels}"/>
                            </lvc:CartesianChart.AxisX>
                        </lvc:CartesianChart>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="10" Margin="5">
                        <lvc:PieChart Series="{Binding ShareSeries}" LegendLocation="Bottom" InnerRadius="40"/>
                    </Border>
                </Grid>

                <!-- ДЕПАРТАМЕНТЫ -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="🧽 МОЙКА" Grid.Column="0" Margin="5" FontWeight="Bold">
                        <StackPanel Margin="15">
                            <TextBlock x:Name="WashRevenueText" FontSize="18" FontWeight="Bold" Foreground="#27AE60"/>
                            <TextBlock x:Name="WashCarsText" FontSize="14" Foreground="#7F8C8D" Margin="0,5"/>
                            <TextBlock x:Name="WashProfitText" FontSize="16" FontWeight="Bold" Margin="0,10,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="🔧 АВТОСЕРВИС" Grid.Column="1" Margin="5" FontWeight="Bold">
                        <StackPanel Margin="15">
                            <TextBlock x:Name="ServiceRevenueText" FontSize="18" FontWeight="Bold" Foreground="#27AE60"/>
                            <TextBlock x:Name="ServiceCarsText" FontSize="14" Foreground="#7F8C8D" Margin="0,5"/>
                            <TextBlock x:Name="ServiceProfitText" FontSize="16" FontWeight="Bold" Margin="0,10,0,0"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>

                <!-- СПОСОБЫ ОПЛАТЫ -->
                <TextBlock Text="💳 Способы оплаты за период" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" Foreground="#2C3E50"/>
                <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="💵 Наличные" Foreground="#7F8C8D" FontSize="12"/>
                            <TextBlock x:Name="CashTotalText" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="💳 Карта" Foreground="#7F8C8D" FontSize="12"/>
                            <TextBlock x:Name="CardTotalText" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="📱 Перевод" Foreground="#7F8C8D" FontSize="12"/>
                            <TextBlock x:Name="TransferTotalText" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                            <TextBlock Text="📱 QR-код" Foreground="#7F8C8D" FontSize="12"/>
                            <TextBlock x:Name="QrTotalText" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Зарплата -->
                <TextBlock Text="💰 Зарплатная ведомость (Итого)" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" Foreground="#2C3E50"/>
                <ListView x:Name="EmployeesSalaryList" MinHeight="150" Background="White" Margin="0,5" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Сотрудник" Width="250" DisplayMemberBinding="{Binding EmployeeName}"/>
                            <GridViewColumn Header="Заказов" Width="80" DisplayMemberBinding="{Binding CarsWashed}"/>
                            <GridViewColumn Header="Начислено" Width="120" DisplayMemberBinding="{Binding Earnings, StringFormat={}{0:N0} ₽}"/>
                            <GridViewColumn Header="Авансы" Width="100" DisplayMemberBinding="{Binding Advances, StringFormat={}{0:N0} ₽}"/>
                            <GridViewColumn Header="К ВЫПЛАТЕ" Width="150" DisplayMemberBinding="{Binding ToPay, StringFormat={}{0:N0} ₽}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
            <Button Content="📄 В Excel" Click="ExportButton_Click" Background="#27AE60" Foreground="White" Width="130" Height="35" Margin="5"/>
            <Button Content="✖ Закрыть" Click="CloseButton_Click" Background="#E74C3C" Foreground="White" Width="120" Height="35" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
