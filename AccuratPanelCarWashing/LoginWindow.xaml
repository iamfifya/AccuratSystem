<Window x:Class="AccuratPanelCarWashing.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AccuratPanelCarWashing"
        xmlns:controls="clr-namespace:AccuratPanelCarWashing.Controls" 
        mc:Ignorable="d"
        Title="Авторизация"
        WindowStartupLocation="CenterScreen"
        Height="600" Width="400"
        Background="#F5F6FA"
        BorderBrush="Black"
        BorderThickness="1"
        WindowStyle="None">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ACCURAT" FontSize="48" 
               Foreground="Black" HorizontalAlignment="Center" Margin="0,0,0,20" Grid.Row="0" 
               FontFamily="Cascadia Mono Light"/>

        <StackPanel x:Name="LoginPanel" Grid.Row="1" VerticalAlignment="Center" Visibility="Visible">
            <Label Content="Логин:" Margin="0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="LoginTextBox" Margin="0,5" Height="50" Padding="5" Foreground="Black"/>

            <Label Content="Пароль:" Margin="0,5" FontWeight="SemiBold"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,5" Height="50" Padding="5" 
                     VerticalContentAlignment="Center" Foreground="Black"/>
        </StackPanel>

        <StackPanel x:Name="BranchSelectionPanel" Grid.Row="1" VerticalAlignment="Center" Visibility="Collapsed">
            <Label Content="Рабочая точка (Филиал):" Margin="0,5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <controls:CustomComboBox x:Name="BranchComboBox" 
                                 Margin="0,15,0,10" 
                                 Height="50"
                                 Placeholder="Выберите место работы"
                                 DisplayMemberPath="Name"
                                 SelectedValuePath="Id"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,20">
            <Button x:Name="ActionBtn" Content="Войти" Click="ActionBtn_Click" Width="120" Height="40" 
                Margin="5" Background="#27AE60" Foreground="White" Cursor="Hand" FontWeight="Bold" IsDefault="True"/>
            <Button Content="Выход" Click="ExitButton_Click" Width="120" Height="40" 
                Margin="5" Background="#E74C3C" Foreground="White" Cursor="Hand" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
