<Window x:Class="AccuratPanelCarWashing.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AccuratPanelCarWashing"
        xmlns:controls="clr-namespace:AccuratPanelCarWashing.Controls" 
        mc:Ignorable="d"
        Title="Авторизация"
        WindowStartupLocation="CenterScreen"
        Height="600" Width="400"
        Background="#F5F6FA"
        BorderBrush="Black"
        BorderThickness="1"
        WindowStyle="None">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Заголовок "Accurat" -->
            <RowDefinition Height="Auto"/>
            <!-- 1: Логин Label -->
            <RowDefinition Height="Auto"/>
            <!-- 2: Логин TextBox -->
            <RowDefinition Height="Auto"/>
            <!-- 3: Пароль Label -->
            <RowDefinition Height="Auto"/>
            <!-- 4: Пароль PasswordBox -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- 5: Кастомный филиал -->
            <RowDefinition Height="*"/>
            <!-- 6: Кнопки -->
        </Grid.RowDefinitions>

        <TextBlock Text="ACCURAT" FontSize="48" 
                   Foreground="Black" HorizontalAlignment="Center" Margin="0,0,0,20" Grid.Row="0" 
                   FontFamily="Cascadia Mono Light"/>

        <Label Content="Логин:" Grid.Row="1" Margin="0,5" FontWeight="SemiBold"/>
        <TextBox x:Name="LoginTextBox" Grid.Row="2" Margin="0,5" Height="50" Padding="5" Foreground="Black"/>

        <Label Content="Пароль:" Grid.Row="3" Margin="0,5" FontWeight="SemiBold"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="4" Margin="0,5" Height="50" Padding="5" 
                     VerticalContentAlignment="Center" Foreground="Black"/>

        <!-- Твой новый кастомный комбобокс -->
        <Label Content="Рабочая точка(Филиал):" Grid.Row="5" Margin="0,5" FontWeight="SemiBold"/>
        <controls:CustomComboBox x:Name="BranchComboBox" 
                                 Grid.Row="6" 
                                 Margin="0,5,0,10" 
                                 Height="50"
                                 Placeholder="Выберите место работы"
                                 DisplayMemberPath="Name"
                                 SelectedValuePath="Id"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,20">
            <Button Content="Войти" Click="LoginButton_Click" Width="120" Height="40" 
                    Margin="5" Background="#27AE60" Foreground="White" Cursor="Hand" FontWeight="Bold"/>
            <Button Content="Выход" Click="ExitButton_Click" Width="120" Height="40" 
                    Margin="5" Background="#E74C3C" Foreground="White" Cursor="Hand" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
