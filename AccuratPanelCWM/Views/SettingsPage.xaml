<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AccuratPanelCWM.Views.SettingsPage"
             Title="Настройки"
             BackgroundColor="{AppThemeBinding Light=#F5F6FA, Dark=#121212}">

    <ScrollView Padding="15">
        <VerticalStackLayout Spacing="20">

            <Label Text="🌐 Подключение к серверу" FontAttributes="Bold" FontSize="16" Margin="5,0,0,0"/>
            <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Адрес API (URL)" FontSize="12" TextColor="#7F8C8D"/>
                    <Entry Text="{Binding ServerUrl}" 
                           Placeholder="https://твой-сервер.ru/api/" 
                           Keyboard="Url"
                           ClearButtonVisibility="WhileEditing"/>

                    <Button Text="Сохранить адрес" 
                            Command="{Binding SaveUrlCommand}"
                            BackgroundColor="#3498DB" 
                            TextColor="White" 
                            CornerRadius="8" 
                            HeightRequest="45"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Border>

            <Label Text="🎨 Внешний вид" FontAttributes="Bold" FontSize="16" Margin="5,10,0,0"/>
            <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Тема оформления" FontSize="12" TextColor="#7F8C8D"/>

                    <Picker Title="Выберите тему"
                            SelectedIndex="{Binding SelectedThemeIndex}">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Как в системе</x:String>
                                <x:String>Светлая</x:String>
                                <x:String>Ночная</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </VerticalStackLayout>
            </Border>

            <Label Text="👤 Аккаунт" FontAttributes="Bold" FontSize="16" Margin="5,10,0,0"/>
            <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="15">
                <Button Text="🚪 Выйти из аккаунта" 
                        Command="{Binding LogoutCommand}"
                        BackgroundColor="#E74C3C" 
                        TextColor="White" 
                        FontAttributes="Bold"
                        CornerRadius="8" 
                        HeightRequest="50"/>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>