<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AccuratPanelCWM.Views.ManagementPage"
             Title="Управление сменой">

    <ScrollView>
        <!-- Свайп для обновления данных -->
        <RefreshView x:Name="ShiftRefreshView" Refreshing="RefreshView_Refreshing">
            <VerticalStackLayout Spacing="20" Padding="15">

                <!-- КАРТОЧКА СТАТУСА -->
                <Border x:Name="StatusBorder" StrokeShape="RoundRectangle 12" Padding="20" StrokeThickness="0">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.1" Offset="0,2" Radius="5" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label x:Name="StatusIconLabel" Text="🔒" FontSize="48" HorizontalOptions="Center"/>
                        <Label x:Name="StatusTitleLabel" Text="Смена закрыта" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label x:Name="StatusDescLabel" Text="Откройте смену, чтобы начать принимать заказы" FontSize="14" TextColor="#7F8C8D" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- НОВЫЙ БЛОК: Выбор сотрудников (виден только при закрытой смене) -->
                <VerticalStackLayout x:Name="EmployeeSelectionLayout" Spacing="10" IsVisible="True">
                    <Label Text="👥 Выберите сотрудников на смену:" FontAttributes="Bold" FontSize="16" />

                    <!-- Используем BindableLayout для списка с чекбоксами -->
                    <VerticalStackLayout x:Name="EmployeesStack" Spacing="5">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <HorizontalStackLayout Spacing="10" Padding="5">
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"  VerticalOptions="Center" Color="#27AE60" />
                                    <Label Text="{Binding FullName}" VerticalOptions="Center" FontSize="14" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- КАРТОЧКА СТАТИСТИКИ (Скрыта, если смена закрыта) -->
                <VerticalStackLayout x:Name="StatsLayout" Spacing="15" IsVisible="False">
                    <Label Text="📊 Показатели текущей смены" FontSize="16" FontAttributes="Bold" Margin="5,10,0,0"/>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">

                        <!-- Выручка -->
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 10" Padding="15" StrokeThickness="0">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Выручка" FontSize="12"/>
                                <Label x:Name="RevenueLabel" Text="0 ₽" FontSize="18" FontAttributes="Bold" TextColor="#27AE60" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Наличные в кассе -->
                        <Border Grid.Column="1" StrokeShape="RoundRectangle 10" Padding="15" StrokeThickness="0">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="В кассе (Наличные)" FontSize="12"/>
                                <Label x:Name="CashInHandLabel" Text="0 ₽" FontSize="18" FontAttributes="Bold" TextColor="#3498DB" />
                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </VerticalStackLayout>

                <!-- КНОПКИ -->
                <!-- Появится только когда смена открыта -->
                <Button x:Name="CashboxButton" Text="💰 Трансфер сумм" BackgroundColor="#3498DB" TextColor="White" FontAttributes="Bold" FontSize="16" CornerRadius="8" HeightRequest="50" Clicked="CashboxButton_Clicked" IsVisible="False"/>

                <Button x:Name="ActionShiftButton" Text="Начать смену" BackgroundColor="#27AE60" TextColor="White" FontAttributes="Bold" FontSize="16" CornerRadius="8" HeightRequest="50" Clicked="ActionShiftButton_Clicked" Margin="0,15,0,0" />

            </VerticalStackLayout>
        </RefreshView>
    </ScrollView>
</ContentPage>