<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AccuratPanelCWM.Views.ManagementPage"
             Title="Управление сменой">

    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding LoadShiftDataCommand}">
        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="15">

                <Border StrokeShape="RoundRectangle 12" Padding="20" StrokeThickness="0">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.1" Offset="0,2" Radius="5" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="{Binding StatusIcon}" FontSize="48" HorizontalOptions="Center"/>
                        <Label Text="{Binding StatusTitle}" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="{Binding StatusDescription}" FontSize="14" TextColor="#7F8C8D" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="10" IsVisible="{Binding IsShiftClosed}">
                    <Label Text="👥 Выберите сотрудников на смену:" FontAttributes="Bold" FontSize="16" />

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding SelectableEmployees}" Spacing="5">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <HorizontalStackLayout Spacing="10" Padding="5">
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalOptions="Center" Color="#27AE60" />
                                    <Label Text="{Binding FullName}" VerticalOptions="Center" FontSize="14" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="15" IsVisible="{Binding IsShiftOpen}">
                    <Label Text="📊 Показатели текущей смены" FontSize="16" FontAttributes="Bold" Margin="5,10,0,0"/>
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 10" Padding="15" StrokeThickness="0">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Выручка" FontSize="12"/>
                                <Label Text="{Binding RevenueDisplay}" FontSize="18" FontAttributes="Bold" TextColor="#27AE60" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" StrokeShape="RoundRectangle 10" Padding="15" StrokeThickness="0">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="В кассе (Наличные)" FontSize="12"/>
                                <Label Text="{Binding CashInHandDisplay}" FontSize="18" FontAttributes="Bold" TextColor="#3498DB" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <Button Text="💰 Трансфер сумм" BackgroundColor="#3498DB" TextColor="White" FontAttributes="Bold" FontSize="16" CornerRadius="8" HeightRequest="50" 
                        Command="{Binding OpenCashboxCommand}" IsVisible="{Binding IsShiftOpen}"/>

                <Button Text="{Binding ActionButtonText}" BackgroundColor="{Binding ActionButtonColor}" TextColor="White" FontAttributes="Bold" FontSize="16" CornerRadius="8" HeightRequest="50" 
                        Command="{Binding ActionShiftCommand}" Margin="0,15,0,0" />

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>