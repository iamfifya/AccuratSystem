<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AccuratPanelCWM.Views.CashboxPage"
             Title="Касса смены">

    <Grid>
        <Grid RowDefinitions="*, Auto" Padding="15">

            <ScrollView Grid.Row="0">
                <VerticalStackLayout Spacing="20">

                    <Border StrokeShape="RoundRectangle 12" Padding="20" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="➕ Новая операция" FontSize="18" FontAttributes="Bold" />

                            <Label Text="Тип операции:" FontAttributes="Bold" FontSize="12" />
                            <Picker Title="Выберите тип..." 
                                    ItemsSource="{Binding TransactionTypes}" 
                                    SelectedItem="{Binding SelectedType}" />

                            <VerticalStackLayout Spacing="5" IsVisible="{Binding IsEmployeeVisible}">
                                <Label Text="Кому выдаем аванс?" FontAttributes="Bold" FontSize="12" />
                                <Picker Title="Выберите сотрудника..." 
                                        ItemsSource="{Binding Employees}" 
                                        SelectedItem="{Binding SelectedEmployee}" 
                                        ItemDisplayBinding="{Binding FullName}" />
                            </VerticalStackLayout>

                            <Label Text="Сумма (₽):" FontAttributes="Bold" FontSize="12" />
                            <Entry Text="{Binding AmountText}" Placeholder="0" Keyboard="Numeric" FontSize="18" />

                            <Label Text="Комментарий:" FontAttributes="Bold" FontSize="12" />
                            <Entry Text="{Binding CommentText}" Placeholder="На что потрачено / кто взял" />

                            <Button Text="Провести операцию" Command="{Binding SaveTransactionCommand}" 
                                    BackgroundColor="#3498DB" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="45" Margin="0,10,0,0"/>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="📜 Лента операций" FontAttributes="Bold" FontSize="16" Margin="5,10,0,0"/>

                    <CollectionView ItemsSource="{Binding Transactions}" HeightRequest="300" EmptyView="Лента пуста">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="10" ColumnDefinitions="40, *, Auto">
                                    <Label Grid.Column="0" Text="{Binding Icon}" FontSize="20" VerticalOptions="Center"/>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="10,0">
                                        <Label Text="{Binding BaseTrans.Type}" FontAttributes="Bold" FontSize="12"/>
                                        <Label Text="{Binding BaseTrans.Comment}" FontSize="11" TextColor="#7F8C8D"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="{Binding FormattedAmount}" FontAttributes="Bold" 
                                           TextColor="{Binding ColorHex}" VerticalOptions="Center"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>

            <Button Grid.Row="1" Text="Закрыть" Command="{Binding CloseCommand}" Margin="0,10"
                    BackgroundColor="#E74C3C" TextColor="White" CornerRadius="8" HeightRequest="45" />
        </Grid>

        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#3498DB" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="50" HeightRequest="50" />
    </Grid>
</ContentPage>