<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AccuratPanelCWM.Views.CashboxPage"
             Title="Касса смены">

    <Grid RowDefinitions="*, Auto" Padding="15">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="20">

                <!-- ФОРМА НОВОЙ ОПЕРАЦИИ -->
                <Border StrokeShape="RoundRectangle 12" Padding="20" StrokeThickness="0">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="➕ Новая операция" FontSize="18" FontAttributes="Bold" />

                        <Label Text="Тип операции:" FontAttributes="Bold" FontSize="12" />
                        <Picker x:Name="TypePicker" Title="Выберите тип..." SelectedIndexChanged="TypePicker_SelectedIndexChanged">
                            <Picker.Items>
                                <x:String>Приход</x:String>
                                <x:String>Расход</x:String>
                                <x:String>Аванс мойщику</x:String>
                                <x:String>Инкассация</x:String>
                                <x:String>Размен</x:String>
                            </Picker.Items>
                        </Picker>

                        <!-- Выбор сотрудника (виден только для аванса) -->
                        <VerticalStackLayout x:Name="EmployeeLayout" IsVisible="False">
                            <Label Text="Кому выдаем аванс?" FontAttributes="Bold" FontSize="12" />
                            <Picker x:Name="EmployeePicker" Title="Выберите сотрудника..." ItemDisplayBinding="{Binding FullName}" />
                        </VerticalStackLayout>

                        <Label Text="Сумма (₽):" FontAttributes="Bold" FontSize="12" />
                        <Entry x:Name="AmountEntry" Placeholder="0" Keyboard="Numeric" FontSize="18" />

                        <Label Text="Комментарий:" FontAttributes="Bold" FontSize="12" />
                        <Entry x:Name="CommentEntry" Placeholder="На что потрачено / кто взял" />

                        <Button Text="Провести операцию" Clicked="Save_Clicked" 
                                BackgroundColor="#3498DB" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="45" />
                    </VerticalStackLayout>
                </Border>

                <!-- ЛЕНТА ОПЕРАЦИЙ (Как в WPF) -->
                <Label Text="📜 Лента операций" FontAttributes="Bold" FontSize="16" Margin="5,10,0,0"/>
                <CollectionView x:Name="TransactionsCollectionView" HeightRequest="300">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="10" ColumnDefinitions="40, *, Auto">
                                <Label Grid.Column="0" Text="{Binding Icon}" FontSize="20" VerticalOptions="Center"/>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="10,0">
                                    <Label Text="{Binding Type}" FontAttributes="Bold" FontSize="12"/>
                                    <Label Text="{Binding Comment}" FontSize="11" TextColor="#7F8C8D"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="{Binding FormattedAmount}" FontAttributes="Bold" 
                                       TextColor="{Binding ColorHex}" VerticalOptions="Center"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="1" Text="Закрыть" Clicked="Cancel_Clicked" Margin="0,10"
                BackgroundColor="#E74C3C" TextColor="White" CornerRadius="8" HeightRequest="45" />
    </Grid>
</ContentPage>